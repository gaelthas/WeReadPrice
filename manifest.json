{
  "manifest_version": 3,
  "name": "微信读书价格助手",
  "version": "1.0.0",
  "description": "在微信读书书架页面显示书籍价格",
  "permissions": ["storage"],
  "host_permissions": ["https://weread.qq.com/*"],
  "background": {
    "service_worker": "src/background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://weread.qq.com/*"],
      "js": ["src/content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
